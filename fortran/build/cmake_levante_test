#!/usr/bin/bash
set -eu  # `man set` then search set \[ and look at options
usage=$(cat << EOF
Usage: $0 [-h]

Configures, builds, and runs tests for miniWeather on Levante. Use as a 
sanity check to make sure miniweather actually works.
EOF
)

if [[ ${1:-"no-help"} == "-h" || ${1:-"no-help"} == "--help" ]]
then
    echo "${usage}"
    exit 0
fi

# source code directory and build configuration directory
fortran_project_root="$(dirname $(dirname $(realpath ${BASH_SOURCE[0]})))"
build_dir="${fortran_project_root}/build"
subdir="test"
build_output_dir="${build_dir}/build_output/${subdir}"

# configure and build miniweather 
config_and_build="${build_dir}/cmake_levante_config_and_build"
bash "${config_and_build}" 200 100 1000 2000 "${subdir}" ON ON

# Without this, openmp test will hang
module purge
module load \
    gcc/11.2.0-gcc-11.2.0 \
    openmpi/4.1.2-gcc-11.2.0 \
    parallel-netcdf/1.12.2-openmpi-4.1.2-gcc-11.2.0 \
    netcdf-c/main-openmpi-4.1.5-nvhpc-24.7

# perform tests 
export TEST_MPI_COMMAND="mpirun -n 1"  # used by check_output.sh
cp "${build_dir}/check_output.sh" "${build_output_dir}"
cd "${build_output_dir}"
ctest 
