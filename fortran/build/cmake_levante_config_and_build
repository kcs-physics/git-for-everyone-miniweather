#!/usr/bin/bash
#
# @brief Configures and builds miniweather on Levante
#
set -eu  # `man set` then search set \[ and look at options

default_required="REQUIRED"
default_build_testing="OFF"
default_delete_build_output_subdir_basename="OFF"
usage=$(cat << EOF
Usage: $0 NX NZ SIM_TIME OUT_FREQ BUILD_OUTPUT_SUBDIR 
        [BUILD_TESTING] [DELETE_BUILD_OUTPUT]

Configure and build miniweather via CMake.

Required arguments:
  NX                         Number of grid points in x-direction
  NZ                         Number of grid points in z-direction
  SIM_TIME                   Total simulation time
  OUT_FREQ                   Output frequency
  BUILD_OUTPUT_SUBDIR        Name of subdirectory created inside build_output/

Optional arguments:
  BUILD_TESTING              Enable CMake testing (default: ${default_build_testing})
                             Valid values: ON | OFF

  DELETE_BUILD_OUTPUT        Delete existing build_output/BUILD_OUTPUT_SUBDIR
                             before configuring (default: ${default_delete_build_output_subdir_basename})
                             Valid values: ON | OFF

Example:
  $0 256 128 1000 10 run1 OFF OFF

Notes:
  - Required arguments must always be provided.
  - Optional arguments default to the values shown above if omitted.
EOF
)

# Get arguments
nx="${1:-$default_required}"
nz="${2:-$default_required}"
sim_time="${3:-$default_required}"
out_freq="${4:-$default_required}"
build_output_subdir_basename="${5:-$default_required}"
build_testing="${6:-$default_build_testing}"
delete_build_output_subdir_basename="${7:-$default_delete_build_output_subdir_basename}"

if [[ "${nx}" == "-h" || "${nx}" == "--help" ]]
then
    echo "${usage}"
    exit 0
fi

# validate args
function validate_required_arg() {
    local required_arg="${1:-$default_required}"
    if [[ "${required_arg}" == "${default_required}" ]]
    then
        echo "[ERROR] Missing required argument"
        echo "  Try $0 -h"
        exit 1 
    fi
}

function validate_int_arg() {
    local int_arg="${1:-$default_required}"
    validate_required_arg "${int_arg}"

    if [[ "${int_arg}" -lt 1 ]]
    then
        echo "[ERROR] Any integer arguments must be greater than 1"
        echo "  Got ${int_arg}"
        echo "  Try $0 -h"
        exit 1 
    fi

    if [[ "${int_arg}" == *"."* ]]
    then
        echo "[ERROR] Argument is not an integer"
        echo "  Got ${int_arg}"
        echo "  Try $0 -h"
        exit 1 
    fi
}

function validate_bool_arg() {
    local bool_arg="${1:-$default_required}"
    validate_required_arg "${bool_arg}"

    if [[ ! "${bool_arg}" == "ON" && ! "${bool_arg}" == "OFF" ]] 
    then
        echo "[ERROR] Bool arg must be either ON or OFF"
        echo "  Got ${bool_arg}"
        echo "  Try $0 -h"
        exit 1 
    fi 
}

validate_required_arg "${nx}"
validate_int_arg "${nx}"

validate_required_arg "${nz}"
validate_int_arg "${nz}"

validate_required_arg "${sim_time}"
validate_int_arg "${sim_time}"

validate_required_arg "${out_freq}"
validate_int_arg "${out_freq}"

validate_required_arg "${build_output_subdir_basename}"
if [[ "${build_output_subdir_basename}" == *"/"* ]]
then
    echo "[ERROR] BUILD_OUTPUT_SUBDIR should be a basename, not a full path"
    echo "  Got ${build_output_subdir_basename}"
    echo "  Try $0 -h"
    exit 1 
fi

# source code, configuration, and compile (build) output directory
fortran_project_root="$(dirname $(dirname $(realpath ${BASH_SOURCE[0]})))"
build_dir="${fortran_project_root}/build"
build_output_dir="${build_dir}/build_output/${build_output_subdir_basename}"

# Flag to delete the build output directory... needed sometimes when
# changing any CMakeLists.txt files
if [[ "${delete_build_output_subdir_basename}" == "ON" ]]
then
    echo "[WARNING] Deleting ${build_output_dir}"
    if [[ -d "${build_output_dir}" ]]
    then
        rm -rf ${build_output_dir}
    fi
fi

# load dependencies 
module purge
module load \
    gcc/11.2.0-gcc-11.2.0 \
    openmpi/4.1.2-gcc-11.2.0 \
    parallel-netcdf/1.12.2-openmpi-4.1.2-gcc-11.2.0 \
    netcdf-c/main-openmpi-4.1.5-nvhpc-24.7

# configure project 
PARALLEL_NETCDF_L_LIBDIR="$(pkg-config --libs-only-L pnetcdf)"
PARALLEL_NETCDF_LIBDIR="${PARALLEL_NETCDF_L_LIBDIR/-L/}"
cmake \
    -S "${fortran_project_root}" -B "${build_output_dir}" \
    -DCMAKE_Fortran_COMPILER=mpif90 \
    -DFFLAGS="-O3 -ffree-line-length-none -I$(pkg-config --variable=includedir pnetcdf)" \
    -DLDFLAGS="$(pkg-config --libs pnetcdf) -Wl,-rpath,${PARALLEL_NETCDF_LIBDIR}" \
    -DOPENMP_FLAGS="-fopenmp" \
    -DBUILD_TESTING="${build_testing}" \
    -DNX="${nx}" \
    -DNZ="${nz}" \
    -DSIM_TIME="${sim_time}" \
    -DOUT_FREQ="${out_freq}"

# build executables
cmake --build "${build_output_dir}"

echo "[SUCCESS] miniweather compiled to ${build_output_dir}"
